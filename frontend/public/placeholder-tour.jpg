<svg xmlns="http://www.w3.org/2000/svg" width="800" height="500" viewBox="0 0 800 500">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e8f4f8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#c9e6f0;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="mountain1" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#5ba3c9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3d7fa8;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="mountain2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#7bbdd9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#5b9ec0;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Sky Background -->
  <rect width="800" height="500" fill="url(#bg)" />

  <!-- Sun -->
  <circle cx="680" cy="100" r="55" fill="#fde68a" opacity="0.8"/>
  <circle cx="680" cy="100" r="42" fill="#fcd34d"/>

  <!-- Clouds -->
  <ellipse cx="150" cy="80" rx="70" ry="28" fill="white" opacity="0.7"/>
  <ellipse cx="200" cy="70" rx="55" ry="22" fill="white" opacity="0.7"/>
  <ellipse cx="100" cy="75" rx="45" ry="18" fill="white" opacity="0.7"/>

  <ellipse cx="500" cy="60" rx="60" ry="24" fill="white" opacity="0.6"/>
  <ellipse cx="545" cy="50" rx="48" ry="20" fill="white" opacity="0.6"/>
  <ellipse cx="455" cy="56" rx="40" ry="16" fill="white" opacity="0.6"/>

  <!-- Mountains back -->
  <polygon points="0,380 200,150 400,380" fill="url(#mountain2)" opacity="0.6"/>
  <polygon points="200,380 450,120 700,380" fill="url(#mountain1)" opacity="0.7"/>
  <polygon points="450,380 700,160 800,380" fill="url(#mountain2)" opacity="0.6"/>

  <!-- Snow caps -->
  <polygon points="200,150 220,190 180,190" fill="white" opacity="0.85"/>
  <polygon points="450,120 475,165 425,165" fill="white" opacity="0.85"/>
  <polygon points="700,160 720,200 680,200" fill="white" opacity="0.85"/>

  <!-- Ground / Grass -->
  <rect y="370" width="800" height="130" fill="#7bbc6e"/>
  <ellipse cx="400" cy="372" rx="420" ry="18" fill="#5ea84f" opacity="0.5"/>

  <!-- Trees left -->
  <rect x="55" y="310" width="12" height="70" fill="#5d4037"/>
  <polygon points="61,220 35,330 87,330" fill="#388e3c"/>
  <polygon points="61,260 40,345 82,345" fill="#43a047"/>

  <rect x="120" y="330" width="10" height="55" fill="#5d4037"/>
  <polygon points="125,250 103,340 147,340" fill="#388e3c"/>
  <polygon points="125,285 108,350 142,350" fill="#43a047"/>

  <!-- Trees right -->
  <rect x="690" y="310" width="12" height="70" fill="#5d4037"/>
  <polygon points="696,220 670,330 722,330" fill="#388e3c"/>
  <polygon points="696,260 675,345 717,345" fill="#43a047"/>

  <rect x="745" y="330" width="10" height="55" fill="#5d4037"/>
  <polygon points="750,250 728,340 772,340" fill="#388e3c"/>
  <polygon points="750,285 733,350 767,350" fill="#43a047"/>

  <!-- Camera icon in center -->
  <rect x="330" y="285" width="140" height="100" rx="12" fill="white" opacity="0.85"/>
  <rect x="345" y="295" width="110" height="78" rx="8" fill="#e0eef5"/>
  <circle cx="400" cy="335" r="22" fill="none" stroke="#5ba3c9" stroke-width="4"/>
  <circle cx="400" cy="335" r="14" fill="#5ba3c9" opacity="0.5"/>
  <rect x="380" y="296" width="28" height="12" rx="4" fill="#5ba3c9" opacity="0.6"/>

  <!-- Label -->
  <text x="400" y="415" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#3d7fa8" font-weight="600" opacity="0.9">Ảnh tour sắp có</text>
  <text x="400" y="438" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#5b9ec0" opacity="0.75">Hình ảnh đang được cập nhật...</text>
</svg>
