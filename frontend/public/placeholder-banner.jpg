<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="400" viewBox="0 0 1200 400">
  <defs>
    <linearGradient id="bannerBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a5f;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2d6a9f;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a4971;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="wave" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#4fa8d5;stop-opacity:0.4" />
      <stop offset="50%" style="stop-color:#76c3e8;stop-opacity:0.6" />
      <stop offset="100%" style="stop-color:#4fa8d5;stop-opacity:0.4" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="400" fill="url(#bannerBg)"/>

  <!-- Stars -->
  <circle cx="100" cy="50" r="1.5" fill="white" opacity="0.6"/>
  <circle cx="250" cy="30" r="1" fill="white" opacity="0.5"/>
  <circle cx="450" cy="60" r="2" fill="white" opacity="0.4"/>
  <circle cx="700" cy="25" r="1.5" fill="white" opacity="0.6"/>
  <circle cx="900" cy="45" r="1" fill="white" opacity="0.5"/>
  <circle cx="1100" cy="35" r="2" fill="white" opacity="0.4"/>
  <circle cx="1050" cy="70" r="1" fill="white" opacity="0.3"/>
  <circle cx="380" cy="90" r="1.5" fill="white" opacity="0.4"/>
  <circle cx="820" cy="80" r="1" fill="white" opacity="0.5"/>

  <!-- Abstract wave shapes -->
  <path d="M 0 280 Q 200 240 400 270 Q 600 300 800 255 Q 1000 210 1200 250 L 1200 400 L 0 400 Z" fill="url(#wave)"/>
  <path d="M 0 320 Q 300 290 600 310 Q 900 330 1200 300 L 1200 400 L 0 400 Z" fill="white" opacity="0.08"/>

  <!-- Geometric circles decoration -->
  <circle cx="120" cy="200" r="90" fill="none" stroke="white" stroke-width="1" opacity="0.1"/>
  <circle cx="120" cy="200" r="60" fill="none" stroke="white" stroke-width="1" opacity="0.1"/>
  <circle cx="1080" cy="200" r="90" fill="none" stroke="white" stroke-width="1" opacity="0.1"/>
  <circle cx="1080" cy="200" r="60" fill="none" stroke="white" stroke-width="1" opacity="0.1"/>

  <!-- Airplane icon -->
  <g transform="translate(560, 140)">
    <path d="M10 0 L22 12 L10 24 L10 15 L-8 20 L-8 4 L10 9 Z" fill="white" opacity="0.9" transform="rotate(-30)"/>
  </g>

  <!-- Center text -->
  <text x="600" y="175" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-size="28" fill="white" font-weight="700" opacity="0.9" letter-spacing="2">✈ KỲ NGHỈ TUYỆT VỜI</text>
  <text x="600" y="215" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-size="16" fill="#a8d8f0" font-weight="400" opacity="0.8">Banner đang được cập nhật</text>
  <text x="600" y="245" text-anchor="middle" font-family="'Helvetica Neue', Arial, sans-serif" font-size="13" fill="#7bbdd9" opacity="0.7">Hình ảnh sẽ sớm hiển thị...</text>
</svg>
