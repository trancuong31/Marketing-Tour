<svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200">
  <defs>
    <linearGradient id="avatarBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#5ba3c9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3d7fa8;stop-opacity:1" />
    </linearGradient>
  </defs>
  <circle cx="100" cy="100" r="100" fill="url(#avatarBg)"/>
  <!-- Head -->
  <circle cx="100" cy="78" r="30" fill="white" opacity="0.9"/>
  <!-- Body -->
  <ellipse cx="100" cy="155" rx="42" ry="30" fill="white" opacity="0.9"/>
</svg>
